<?xml version="1.0"?>
<ruleset name="Apta Shield Rules">
    <description>Ruleset for Apta Shield plugin.</description>

    <!-- Exclude dependency directories -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/tests/*</exclude-pattern>

    <!-- Configure WordPress.WP.I18n to accept 'apta-shield' as the correct text domain -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="apta-shield"/>
            </property>
        </properties>
    </rule>
</ruleset>
